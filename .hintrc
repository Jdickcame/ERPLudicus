{
  "extends": ["development"],
  "hints": {
    "axe/name-role-value": [
      "default",
      {
        "button-name": "off",
      },
    ],
    "axe/forms": [
      "default",
      {
        "select-name": "off",
        "label": "off",
      },
    ],
    "button-type": "off",
    "no-inline-styles": "off",
    "axe/aria": [
      "default",
      {
        "empty-table-header": "off",
      },
    ],
    "compat-api/html": [
      "default",
      {
        "ignore": ["input[type=month]"],
      },
    ],
    "typescript-config/is-valid": "off",
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "scrollbar-width",
          "scrollbar-color",
          "scrollbar-width: thin",
        ],
      },
    ],
  },
}
